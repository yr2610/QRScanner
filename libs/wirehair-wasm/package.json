    "repository": {
        "type": "git",
        "url": "git+https://github.com/kig/wirehair-wasm.git"
    },
    "homepage": "https://github.com/kig/wirehair-wasm#readme",
    "bugs": {
        "url": "https://github.com/kig/wirehair-wasm/issues"
    }
